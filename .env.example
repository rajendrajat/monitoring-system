# Environment Variables Template
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to GitHub - it's in .gitignore

# ===========================================
# TELEGRAM CONFIGURATION
# ===========================================
# Get your bot token from: https://t.me/BotFather
# Create a new bot and get the token
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Get your chat ID by messaging your bot and visiting:
# https://api.telegram.org/bot<YourBOTToken>/getUpdates
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ===========================================
# EMAIL CONFIGURATION (Optional)
# ===========================================
# Gmail setup: https://myaccount.google.com/apppasswords
EMAIL_SENDER=your_email@gmail.com
EMAIL_PASSWORD=your_gmail_app_password
EMAIL_RECEIVER=recipient_email@gmail.com

# Alternative email providers:
# EMAIL_SMTP_SERVER=smtp.gmail.com
# EMAIL_SMTP_PORT=587

# ===========================================
# DISCORD CONFIGURATION (Optional)
# ===========================================
# Create webhook: https://discord.com/developers/docs/resources/webhook
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN

# ===========================================
# API KEYS (Optional)
# ===========================================
# Alpha Vantage for real market data: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here

# ===========================================
# SCHEDULER CONFIGURATION
# ===========================================
# Times in 24-hour format (HH:MM)
MONITORING_TIME=09:00
EMAIL_REPORT_TIME=18:00

# ===========================================
# ALERT THRESHOLDS
# ===========================================
# Bitcoin alert threshold (in INR)
BITCOIN_ALERT_THRESHOLD=5000000

# NIFTY drop alert threshold (percentage)
NIFTY_DROP_THRESHOLD=-1.5

# Inflation alert thresholds
INFLATION_CRITICAL_THRESHOLD=6.0
INFLATION_WARNING_THRESHOLD=5.5

# Precious metals alert thresholds
GOLD_HIGH_THRESHOLD=7500
SILVER_HIGH_THRESHOLD=100

# ===========================================
# DEBUG MODE
# ===========================================
DEBUG_MODE=false